    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "HdmrvsvjyW4A"
      },
      "outputs": [],
      "source": [
        "from sklearn.metrics import cohen_kappa_score, f1_score, accuracy_score, precision_score, recall_score\n",
        "\n",
        "def evaluate_model(true, pred):\n",
        "    return {\n",
        "        'Cohens Kappa': cohen_kappa_score(true, pred),\n",
        "        'F1': f1_score(true, pred, average='weighted'),\n",
        "        'Accuracy': accuracy_score(true, pred),\n",
        "        'Precision': precision_score(true, pred, average='weighted'),\n",
        "        'Recall': recall_score(true, pred, average='weighted')\n",
        "    }"
      ]
    },
