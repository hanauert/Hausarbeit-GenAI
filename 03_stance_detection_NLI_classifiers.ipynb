      "outputs": [],
      "source": [
        "\tsamples = list(\"Title:\\n\" + subsample_gold['title'] + \"\\n\\n\" + \"Paragraph:\\n\" + subsample_gold['paragraph'])\n",
        "\ttemplate = \"Der Text impliziert eine {} Meinung zu Migration in Bezug auf Fachkräftemangel.\"\n",
        "\tlabels = ['positive', 'negative', 'keine']"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "AVATL2uxyvzs"
      },
      "outputs": [],
      "source": [
        "# classify the documents\n",
        "res = classifier(samples, labels, hypothesis_template = template, multi_label = False)\n",
        "\n",
        "# return the most probable label and add it to our data frame\n",
        "subsample_gold['label_ml_p6'] = [label['labels'][0] for label in res]\n",
        "\n",
        "subsample_gold['score_ml_p6'] = [r['scores'][0] for r in res]"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "YswIex3pzN0E"
      },
      "outputs": [],
      "source": [
        "adj_to_base = {\n",
        "    'positive': 'positiv',\n",
        "    'negative': 'negativ',\n",
        "    'keine': 'neutral',\n",
        "}\n",
        "\n",
        "# Apply mapping\n",
        "subsample_gold['label_ml_p6'] = subsample_gold['label_ml_p6'].map(adj_to_base)"
      ]
    },
